# Normalize line endings to LF for the entire repository
* text=auto eol=lf

# Explicitly declare text files to always be normalized and converted to native line endings on checkout.
*.c text eol=crlf
*.h text eol=crlf
*.js text eol=crlf
*.css text eol=crlf
*.htlm text eol=crlf
*.sln text eol=crlf
*.json text eol=crlf
.gitattributes text eol=crlf
.gitignore text eol=crlf

# Files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.wasm binary
*.data binary
*.ico binary
*.svg binary
*.gif binary
*.bmp binary
*.tiff binary
