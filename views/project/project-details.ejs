<%- include('head', { title: 'VolWeb' }) -%>
<%
getNameFromPath = function(path) {
    return path.replace(/^.*[\\/]/, '');
}
%>
<script>
    function _(el) {
        return document.getElementById(el);
    }

    function progressHandler(event, progressBarId, statusId) {
        const percent = (event.loaded / event.total) * 100;
        _(progressBarId).value = Math.round(percent);
        _(statusId).innerHTML = Math.round(percent) + "% uploaded... please wait";
    }

    function completeHandler(event, progressBarId, statusId) {
        _(statusId).innerHTML = event.target.responseText;
        const progressBar = _(progressBarId);
        progressBar.value = 0;
        _(progressBarId).style.display = 'none';
    }

    function uploadFile(apiURL, filesField, progressBarId, statusId) {
        const files = _(filesField).files;

        const formdata = new FormData();
        for ( let i = 0; i < files.length; i++ ) {
            console.log(files[i]);
            formdata.append('files', files[i]);
        }
        const ajax = new XMLHttpRequest();
        _(progressBarId).style.display = 'block';
        ajax.upload.addEventListener("progress", (e) => progressHandler(e, progressBarId, statusId), false);
        ajax.addEventListener("load", (e) => completeHandler(e, progressBarId, statusId), false);
        ajax.addEventListener("error", (e) => errorHandler(e, statusId), false);
        ajax.addEventListener("abort", (e) => abortHandler(e, statusId), false);
        // Handle potential redirects
        ajax.onload = function() {
            if (ajax.responseURL) {
                window.location.href = ajax.responseURL;
            }
        };

        ajax.open("POST", apiURL);
        ajax.send(formdata);
    }

    function getNameFromPath(path) {
        return path.replace(/^.*[\\/]/, '');
    }
</script>
<a href="/api/actions/projects">Back to projects list.</a>
<br />
<h1>Vol Web</h1>
<h2>Project <%= project.name %>:</h2>
<p><b>Owner ID:</b> <%= project.userId %></p>
<p><b>Description:</b> <%= project.description %></p>
<p><a href="/api/actions/projects/<%= project.id %>/delete">[Delete] <%= project.description %></a></p>

<br />
<h3 style="text-align: left">Volumes:</h3>
<button id="createVolumeToggle" onClick="(() => {
    const disp = document.getElementById('createVolume').style.display;
    document.getElementById('createVolume').style.display = disp === 'block' ? 'none' : 'block';
    document.getElementById('createVolumeToggle').textContent = disp === 'block' ? 'Add New Volume &darr;' : 'Add New Volume &uarr;';
    })()">Add New Volume &darr;</button>
<form id="createVolume" style="display: none" action="/api/actions/projects/<%= project.id %>/create-volume" method="post" enctype="multipart/form-data">
    <label for="name">Volume name:</label>
    <input type="text" name="name" /> <br />
    <br />
    <label for="description">Volume description:</label>
    <textarea name="description" rows="4" cols="25"></textarea>
    <input type="submit" value="Add" />
</form>
<hr />
<% for (const volume of project.volumes) { %>
    <p>
        <b>Volume:</b> <%= volume.name %> (<%= volume.id %>)
        <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/removeFromProject">[X]</a>
    </p>
    <h4>Raw Data:</h4>
    <% if (volume.rawData != null) { %>
        <% if (volume.rawData.mrcFilePath != null) { %>
            <a href="/api/actions/projects/<%= project.id %>/volumeData/RawVolumeData/<%= volume.rawData.id %>/download-mrc-file"><%= getNameFromPath(volume.rawData.mrcFilePath) %></a> ...
            <a href="/api/actions/projects/<%= project.id %>/volumeData/RawVolumeData/<%= volume.rawData.id %>/delete-mrc-file">[X]</a>
            <br />
        <% } %>
        <% if (volume.rawData.rawFilePath != null) { %>
            <a href="/api/actions/projects/<%= project.id %>/volumeData/RawVolumeData/<%= volume.rawData.id %>/download-raw-file"><%= getNameFromPath(volume.rawData.rawFilePath) %></a> ...
            <a href="/api/actions/projects/<%= project.id %>/volumeData/RawVolumeData/<%= volume.rawData.id %>/delete-raw-file">[X]</a>
            <br />
        <% } %>
        <% if (volume.rawData.settings != null) { %>
            <a href="/api/actions/projects/<%= project.id %>/volumeData/RawVolumeData/<%= volume.rawData.id %>/download-settings-file">Download Settings</a> <br />
        <% } %>
        <% if (volume.rawData.rawFilePath != null && volume.rawData.settings != null) { %>
            <a target="_blank" href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/volumeData/RawVolumeData/<%= volume.rawData.id %>/visualize">Visualize Raw Volume</a><br />
        <% } %>
    <% } %>
    <form method="POST" enctype="multipart/form-data" id="rawDataUpload">
        <label for="file">Select Raw Data Volume files:</label>
        <input type="file" id="rawDataFiles_<%= volume.id %>" name="files" accept="application/zip,.raw,.json" multiple>
        <input
                type="button"
                onclick="uploadFile('/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/raw-data/upload', 'rawDataFiles_<%= volume.id %>', 'progressBarRawData_<%= volume.id %>', 'statusRawData_<%= volume.id %>')"
                value = "Upload">
        <progress id="progressBarRawData_<%= volume.id %>" value="0" max="100" style="width:300px; display: none"></progress>
        <span id="statusRawData_<%= volume.id %>"></span>
    </form>
    <form method="POST" enctype="multipart/form-data" id="rawDataUpload">
        <label for="file">Select MRC file:</label>
        <input type="file" id="mrcFile_<%= volume.id %>" name="files" accept=".mrc">
        <input
            type="button"
            onclick="uploadFile('/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/raw-data/upload-mrc-file', 'mrcFile_<%= volume.id %>', 'progressBarMrcFile_<%= volume.id %>', 'statusMrcFile_<%= volume.id %>')"
            value = "Upload">
        <progress id="progressBarMrcFile_<%= volume.id %>" value="0" max="100" style="width:300px; display: none"></progress>
        <span id="statusMrcFile_<%= volume.id %>"></span>
    </form>
    <h4>Sparse Labels:</h4>
    <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/add-sparse-labeled-volume"><button>Add Sparse Labeled Volume</button></a>
    <br />
    <% for (const sparseLabeledVolume of volume.sparseVolumes) { %>
        <b>Sparse volume <%= sparseLabeledVolume.id %>:</b> <a href="/api/actions/projects/<%= project.id %>/volumeData/SparseLabeledVolumeData/<%= sparseLabeledVolume.id %>/removeFromVolume/<%= volume.id %>">[X]</a>
        <form method="POST" enctype="multipart/form-data">
            <label for="file">Files:</label>
            <input type="file" id="sparseLabeledVolumeFiles_<%= volume.id %>_<%= sparseLabeledVolume.id %>" name="files" accept="application/zip,.raw,.json" multiple>
            <input
                    type="button"
                    onclick="uploadFile('/api/actions/projects/<%= project.id %>/volumeData/SparseLabeledVolumeData/<%= sparseLabeledVolume.id %>/upload-files', 'sparseLabeledVolumeFiles_<%= volume.id %>_<%= sparseLabeledVolume.id %>', 'progressBarSparseLabeledVolume_<%= volume.id %>_<%= sparseLabeledVolume.id %>', 'statusSparseLabeledVolume_<%= volume.id %>_<%= sparseLabeledVolume.id %>')"
                    value = "Upload">
            <progress id="progressBarSparseLabeledVolume_<%= volume.id %>_<%= sparseLabeledVolume.id %>" value="0" max="100" style="width:300px; display: none"></progress>
            <span id="statusSparseLabeledVolume_<%= volume.id %>_<%= sparseLabeledVolume.id %>"></span>
        </form>
        <% if (sparseLabeledVolume.rawFilePath != null) { %>
            <a href="/api/actions/projects/<%= project.id %>/volumeData/SparseLabeledVolumeData/<%= sparseLabeledVolume.id %>/download-raw-file"><%= getNameFromPath(sparseLabeledVolume.rawFilePath) %></a> ...
            <a href="/api/actions/projects/<%= project.id %>/volumeData/SparseLabeledVolumeData/<%= sparseLabeledVolume.id %>/delete-raw-file">[X]</a>
            <br />
        <% } %>
        <% if (sparseLabeledVolume.settings != null) { %>
            <a href="/api/actions/projects/<%= project.id %>/volumeData/SparseLabeledVolumeData/<%= sparseLabeledVolume.id %>/download-settings-file">Download Settings</a> <br />
        <% } %>
        <% if (sparseLabeledVolume.rawFilePath != null && sparseLabeledVolume.settings != null) { %>
            <a target="_blank" href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/volumeData/SparseLabeledVolumeData/<%= sparseLabeledVolume.id %>/visualize">Visualize Raw Volume</a><br />
        <% } %>
    <% } %>
    <h4>Pseudo Labels:</h4>
    <form method="POST" action="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/create-pseudo-labels" enctype="multipart/form-data">
        <input type="submit" value="Create Pseudo Label Volumes" />
    </form>
    <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/add-pseudo-labeled-volume"><button>Add Pseudo Labeled Volume</button></a>
    <br />
    <% for (const pseudoLabeledVolume of volume.pseudoVolumes) { %>
        <b>Pseudo volume <%= pseudoLabeledVolume.id %>:</b> <a href="/api/actions/projects/<%= project.id %>/volumeData/PseudoLabeledVolumeData/<%= pseudoLabeledVolume.id %>/removeFromVolume/<%= volume.id %>">[X]</a>
        <form method="POST" enctype="multipart/form-data">
            <label for="file">Files:</label>
            <input type="file" id="pseudoLabeledVolumeFiles_<%= volume.id %>_<%= pseudoLabeledVolume.id %>" name="files" accept="application/zip,.raw,.json" multiple>
            <input
                    type="button"
                    onclick="uploadFile('/api/actions/projects/<%= project.id %>/volumeData/PseudoLabeledVolumeData/<%= pseudoLabeledVolume.id %>/upload-files', 'pseudoLabeledVolumeFiles_<%= volume.id %>_<%= pseudoLabeledVolume.id %>', 'progressBarPseudoLabeledVolume_<%= volume.id %>_<%= pseudoLabeledVolume.id %>', 'statusPseudoLabeledVolume_<%= volume.id %>_<%= pseudoLabeledVolume.id %>')"
                    value = "Upload">
            <progress id="progressBarPseudoLabeledVolume_<%= volume.id %>_<%= pseudoLabeledVolume.id %>" value="0" max="100" style="width:300px; display: none"></progress>
            <span id="statusPseudoLabeledVolume_<%= volume.id %>_<%= pseudoLabeledVolume.id %>"></span>
        </form>
        <% if (pseudoLabeledVolume.rawFilePath != null) { %>
            <a href="/api/actions/projects/<%= project.id %>/volumeData/PseudoLabeledVolumeData/<%= pseudoLabeledVolume.id %>/download-raw-file"><%= getNameFromPath(pseudoLabeledVolume.rawFilePath) %></a> ...
            <a href="/api/actions/projects/<%= project.id %>/volumeData/PseudoLabeledVolumeData/<%= pseudoLabeledVolume.id %>/delete-raw-file">[X]</a>
            <br />
        <% } %>
        <% if (pseudoLabeledVolume.settings != null) { %>
            <a href="/api/actions/projects/<%= project.id %>/volumeData/PseudoLabeledVolumeData/<%= pseudoLabeledVolume.id %>/download-settings-file">Download Settings</a> <br />
        <% } %>
        <% if (pseudoLabeledVolume.rawFilePath != null && pseudoLabeledVolume.settings != null) { %>
            <a target="_blank" href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/volumeData/PseudoLabeledVolumeData/<%= pseudoLabeledVolume.id %>/visualize">Visualize Raw Volume</a><br />
        <% } %>
    <% } %>
    <h4>Results:</h4>
    <% for (const result of volume.results) { %>
        <p>
            <b>Result id:</b> <%= result.id %>
            <a href="/api/actions/projects/<%= project.id %>/result/<%= result.id %>/removeFromVolume/<%= volume.id %>">[X]</a><br />
            <a href="/api/actions/projects/<%= project.id %>/result/<%= result.id %>/download">Download</a><br />
            <b>Volume Data id:</b> <%= result.volumeDataId %><br />
            <b>Checkpoint id:</b> <%= result.checkpointId %><br />
        </p>
    <% } %>
    <hr />
<% } %>
<br />
<hr />
<h3 style="text-align: left">Models:</h3>
<button id="createModelToggle" onClick="(() => {
    const disp = document.getElementById('createModel').style.display;
    document.getElementById('createModel').style.display = disp === 'block' ? 'none' : 'block';
    document.getElementById('createModelToggle').textContent = disp === 'block' ? 'Add New Model &darr;' : 'Add New Model &uarr;';
    })()">Add New Model &darr;</button>
<form id="createModel" style="display: none" action="/api/actions/projects/<%= project.id %>/create-model" method="post" enctype="multipart/form-data">
    <label for="name">Volume name:</label>
    <input type="text" name="name" /> <br />
    <br />
    <label for="description">Volume description:</label>
    <textarea name="description" rows="4" cols="25"></textarea>
    <input type="submit" value="Add" />
</form>
<% for (const model of project.models) { %>
    <p>
        <b>Model:</b> <%= model.name %> (<%= model.id %>)
        <a href="/api/actions/projects/<%= project.id %>/model/<%= model.id %>/removeFromProject">[X]</a>
    </p>
    <form method="POST" enctype="multipart/form-data">
        <label for="file">Select Checkpoint files:</label>
        <input type="file" id="checkpointFiles" name="files" accept=".ckpt" multiple>
        <input
                type="button"
                onclick="uploadFile('/api/actions/projects/<%= project.id %>/model/<%= model.id %>/add-checkpoint', 'checkpointFiles', 'progressBarCheckpoint', 'statusCheckpoint')"
                value = "Upload">
        <progress id="progressBarCheckpoint" value="0" max="100" style="width:300px; display: none"></progress>
        <span id="statusCheckpoint"></span>
    </form>
    <h4>Checkpoints:</h4>
    <% for (const checkpoint of model.checkpoints) { %>
        <a href="/api/actions/projects/<%= project.id %>/model/<%= model.id %>/checkpoint/<%= checkpoint.id %>/download"><%= getNameFromPath(checkpoint.filePath) %></a> ...
        <a href="/api/actions/projects/<%= project.id %>/model/<%= model.id %>/checkpoint/<%= checkpoint.id %>/removeFromModel">[X]</a>
        <br />
    <% } %>
<% } %>
<hr />
<hr />
<h3 style="text-align: left">Inference:</h3>
<form id="inference" action="/api/actions/projects/<%= project.id %>/run-inference" method="post" enctype="multipart/form-data">
    <label for="inferenceCheckpoint">Checkpoint:</label>
    <select id="inferenceCheckpoint" name="checkpointId" required>
        <% for (const model of project.models) { %>
            <% for (const checkpoint of model.checkpoints) { %>
                <option type="number" value="<%= checkpoint.id %>"><%= getNameFromPath(checkpoint.filePath) %> (<%= checkpoint.id %>)</option>
            <% } %>
        <% } %>
    </select><br />
    <label for="inferenceVolume">Volume:</label>
    <select id="inferenceVolume" name="volumeId" required>
        <% for (const volume of project.volumes) { %>
            <option value="<%= volume.id %>"> <%= volume.name %> (<%= volume.id %>)</option>
        <% } %>
    </select>
    <input type="submit" value="Submit" />
</form>
<hr />
<h3 style="text-align: left">Training:</h3>
<form id="training" action="/api/actions/projects/<%= project.id %>/run-training" method="post" enctype="multipart/form-data">
    <label for="trainingModel">Model:</label>
    <select id="trainingModel" name="modelId" required>
        <% for (const model of project.models) { %>
        <option type="number" value="<%= model.id %>"><%= model.name %> (<%= model.id %>)</option>
        <% } %>
    </select><br />
    <label for="trainingVolumes">Training Volumes:</label>
    <select id="trainingVolumes" name="trainingVolumes" size="5" multiple required>
        <% for (const volume of project.volumes) { %>
            <% if (volume.pseudoVolumes.length > 0) { %>
                <option value="<%= volume.id %>"> <%= volume.name %> (<%= volume.id %>)</option>
            <% } %>
        <% } %>
    </select>
    <label for="validationVolumes">Validation Volumes:</label>
    <select id="validationVolumes" name="validationVolumes" size="5" multiple required>
        <% for (const volume of project.volumes) { %>
            <% if (volume.pseudoVolumes.length > 0) { %>
                <option value="<%= volume.id %>"> <%= volume.name %> (<%= volume.id %>)</option>
            <% } %>
        <% } %>
    </select>
    <label for="testingVolumes">Testing Volumes:</label>
    <select id="testingVolumes" name="testingVolumes" size="5" multiple required>
        <% for (const volume of project.volumes) { %>
            <% if (volume.pseudoVolumes.length > 0) { %>
                <option value="<%= volume.id %>"> <%= volume.name %> (<%= volume.id %>)</option>
            <% } %>
        <% } %>
    </select><br />
    <input type="submit" value="Submit" />
</form>
<hr />
<%- include('foot') -%>