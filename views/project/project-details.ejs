<%- include('head', { title: 'VolWeb' }) -%>
<script>
    function _(el) {
        return document.getElementById(el);
    }

    function progressHandler(event, progressBarId, statusId) {
        const percent = (event.loaded / event.total) * 100;
        _(progressBarId).value = Math.round(percent);
        _(statusId).innerHTML = Math.round(percent) + "% uploaded... please wait";
    }

    function completeHandler(event, progressBarId, statusId) {
        _(statusId).innerHTML = event.target.responseText;
        const progressBar = _(progressBarId);
        progressBar.value = 0;
        _(progressBarId).style.display = 'none';
    }

    function uploadFile(apiURL, filesField, progressBarId, statusId) {
        const files = _(filesField).files;

        const formdata = new FormData();
        for ( let i = 0; i < files.length; i++ ) {
            console.log(files[i]);
            formdata.append('files', files[i]);
        }
        const ajax = new XMLHttpRequest();
        _(progressBarId).style.display = 'block';
        ajax.upload.addEventListener("progress", (e) => progressHandler(e, progressBarId, statusId), false);
        ajax.addEventListener("load", (e) => completeHandler(e, progressBarId, statusId), false);
        ajax.addEventListener("error", (e) => errorHandler(e, statusId), false);
        ajax.addEventListener("abort", (e) => abortHandler(e, statusId), false);
        // Handle potential redirects
        ajax.onload = function() {
            if (ajax.responseURL) {
                window.location.href = ajax.responseURL;
            }
        };

        ajax.open("POST", apiURL);
        ajax.send(formdata);
    }
</script>
<a href="/api/actions/projects">Back to projects list.</a>
<br />
<h1>Vol Web</h1>
<h2>Project <%= project.name %>:</h2>
<p><b>Owner ID:</b> <%= project.userId %></p>
<p><b>Description:</b> <%= project.description %></p>

<br />
<h3 style="text-align: left">Volumes:</h3>
<button id="createVolumeToggle" onClick="(() => {
    const disp = document.getElementById('createVolume').style.display;
    document.getElementById('createVolume').style.display = disp === 'block' ? 'none' : 'block';
    document.getElementById('createVolumeToggle').textContent = disp === 'block' ? 'Add New Volume &darr;' : 'Add New Volume &uarr;';
    })()">Add New Volume &darr;</button>
<form id="createVolume" style="display: none" action="/api/actions/projects/<%= project.id %>/create-volume" method="post" enctype="multipart/form-data">
    <label for="name">Volume name:</label>
    <input type="text" name="name" /> <br />
    <br />
    <label for="description">Volume description:</label>
    <textarea name="description" rows="4" cols="25"></textarea>
    <input type="submit" value="Add" />
</form>
<hr />
<% for (const volume of volumes) { %>
    <p>
        <b>Volume:</b> <%= volume.name %> (<%= volume.id %>)
        <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/delete">[X]</a>
    </p>
    <h4>Raw Data:</h4>
    <% if (volume.rawData != null) { %>
        <% if (volume.rawData.rawFile != null) { %>
            <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/raw-data/download-raw"><%= volume.rawData.rawFile.fileName %></a> ...
            <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/raw-data/delete-raw-file">[X]</a>
            <% if (volume.sparseLabeledVolume.settingsFile != null) { %>
                <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/raw-data/convert-raw-to-tiff"><button>Convert to tiff slices</button></a>
            <% } %>
            <br />
        <% } %>
        <% if (volume.rawData.settingsFile != null) { %>
            <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/raw-data/download-settings"><%= volume.rawData.settingsFile.fileName %></a> ...
            <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/raw-data/delete-settings-file">[X]</a><br />
        <% } %>
        <% if (volume.rawData.tiffFolder != null) { %>
            <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/raw-data/download-tiff">Tiff Files</a> ...
            <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/raw-data/delete-tiff-files">[X]</a><br />
        <% } %>
        <% if (volume.rawData.rawFile != null && volume.rawData.settingsFile != null) { %>
            <a target="_blank" href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/raw-data/visualize">Visualize Raw Volume</a><br />
        <% } %>
    <% } %>
    <form method="POST" enctype="multipart/form-data" id="rawDataUpload">
        <label for="file">Select Raw Data Volume files:</label>
        <input type="file" id="rawDataFiles" name="files" accept="image/tif,image/tiff,application/zip,.raw,.json" multiple>
        <input
                type="button"
                onclick="uploadFile('/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/raw-data/upload', 'rawDataFiles', 'progressBarRawData', 'statusRawData')"
                value = "Upload">
        <progress id="progressBarRawData" value="0" max="100" style="width:300px; display: none"></progress>
        <span id="statusRawData"></span>
    </form>
    <h4>Sparse Labels:</h4>
    <% if (volume.sparseLabeledVolume != null) { %>
        <% if (volume.sparseLabeledVolume.rawFile != null) { %>
            <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/sparse-labeled-volume/download-raw"><%= volume.sparseLabeledVolume.rawFile.fileName %></a> ...
            <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/sparse-labeled-volume/delete-raw-file">[X]</a>
            <% if (volume.sparseLabeledVolume.settingsFile != null) { %>
            <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/sparse-labeled-volume/convert-raw-to-tiff"><button>Convert to tiff slices</button></a>
            <% } %>
            <br />
        <% } %>
        <% if (volume.sparseLabeledVolume.settingsFile != null) { %>
            <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/sparse-labeled-volume/download-settings"><%= volume.sparseLabeledVolume.settingsFile.fileName %></a> ...
            <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/sparse-labeled-volume/delete-settings-file">[X]</a><br />
        <% } %>
        <% if (volume.sparseLabeledVolume.tiffFolder != null) { %>
            <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/sparse-labeled-volume/download-tiff">Tiff Files</a> ...
            <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/sparse-labeled-volume/delete-tiff-files">[X]</a><br />
        <% } %>
        <% if (volume.sparseLabeledVolume.rawFile != null && volume.sparseLabeledVolume.settingsFile != null) { %>
            <a target="_blank" href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/sparse-labeled-volume/visualize">Visualize Raw Volume</a><br />
        <% } %>
    <% } %>
    <form method="POST" enctype="multipart/form-data">
        <label for="file">Select Sparse Labeled Volume files:</label>
        <input type="file" id="sparseLabeledVolumeFiles" name="files" accept="image/tif,image/tiff,application/zip,.raw,.json" multiple>
        <input
                type="button"
                onclick="uploadFile('/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/sparse-labeled-volume/upload', 'sparseLabeledVolumeFiles', 'progressBarSparseLabeledVolume', 'statusSparseLabeledVolume')"
                value = "Upload">
        <progress id="progressBarSparseLabeledVolume" value="0" max="100" style="width:300px; display: none"></progress>
        <span id="statusSparseLabeledVolume"></span>
    </form>
    <h4>Pseudo Labels:</h4>
    <% if (volume.rawData.tiffFolder != null && volume.sparseLabeledVolume.tiffFolder != null) { %>
        <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/pseudo-labeled-volume/create"><button>Infer Pseudo Labels with Ilastik</button></a>
    <% } %>
    <% if (volume.pseudoLabeledVolume != null) { %>
        <% if (volume.pseudoLabeledVolume.rawFile != null) { %>
            <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/pseudo-labeled-volume/download-raw"><%= volume.pseudoLabeledVolume.rawFile.fileName %></a> ...
            <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/pseudo-labeled-volume/delete-raw-file">[X]</a>
            <br />
        <% } %>
        <% if (volume.pseudoLabeledVolume.settingsFile != null) { %>
            <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/pseudo-labeled-volume/download-settings"><%= volume.pseudoLabeledVolume.settingsFile.fileName %></a> ...
            <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/pseudo-labeled-volume/delete-settings-file">[X]</a><br />
        <% } %>
        <% if (volume.pseudoLabeledVolume.tiffFolder != null) { %>
            <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/pseudo-labeled-volume/download-tiff">Tiff Files</a> ...
            <a href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/pseudo-labeled-volume/delete-tiff-files">[X]</a><br />
        <% } %>
        <% if (volume.pseudoLabeledVolume.rawFile != null && volume.pseudoLabeledVolume.settingsFile != null) { %>
            <a target="_blank" href="/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/pseudo-labeled-volume/visualize">Visualize Raw Volume</a><br />
        <% } %>
    <% } %>
    <form method="POST" enctype="multipart/form-data">
        <label for="file">Select Pseudo Labeled Volume files:</label>
        <input type="file" id="pseudoLabeledVolumeFiles" name="files" accept="image/tif,image/tiff,application/zip,.raw,.json" multiple>
        <input
                type="button"
                onclick="uploadFile('/api/actions/projects/<%= project.id %>/volume/<%= volume.id %>/pseudo-labeled-volume/upload', 'pseudoLabeledVolumeFiles', 'progressBarPseudoLabeledVolume', 'pseudoSparseLabeledVolume')"
                value = "Upload">
        <progress id="progressBarPseudoLabeledVolume" value="0" max="100" style="width:300px; display: none"></progress>
        <span id="pseudoSparseLabeledVolume"></span>
    </form>
    <hr />
<% } %>
<br />
<hr />
<h3 style="text-align: left">Models:</h3>
<button id="createModelToggle" onClick="(() => {
    const disp = document.getElementById('createModel').style.display;
    document.getElementById('createModel').style.display = disp === 'block' ? 'none' : 'block';
    document.getElementById('createModelToggle').textContent = disp === 'block' ? 'Add New Model &darr;' : 'Add New Model &uarr;';
    })()">Add New Model &darr;</button>
<form id="createModel" style="display: none" action="/api/actions/projects/<%= project.id %>/create-model" method="post" enctype="multipart/form-data">
    <label for="name">Volume name:</label>
    <input type="text" name="name" /> <br />
    <br />
    <label for="description">Volume description:</label>
    <textarea name="description" rows="4" cols="25"></textarea>
    <input type="submit" value="Add" />
</form>
<% for (let modelIndex = 0; modelIndex < models.length; modelIndex++) { %>
    <p>
        <b>Model:</b> <%= models[modelIndex].name %> (<%= models[modelIndex].id %>)
        <a href="/api/actions/projects/<%= project.id %>/model/<%= models[modelIndex].id %>/delete">[X]</a>
    </p>
    <form method="POST" enctype="multipart/form-data">
        <label for="file">Select Checkpoint files:</label>
        <input type="file" id="checkpointFiles" name="files" accept=".ckpt" multiple>
        <input
                type="button"
                onclick="uploadFile('/api/actions/projects/<%= project.id %>/model/<%= models[modelIndex].id %>/add-checkpoint', 'checkpointFiles', 'progressBarCheckpoint', 'statusCheckpoint')"
                value = "Upload">
        <progress id="progressBarCheckpoint" value="0" max="100" style="width:300px; display: none"></progress>
        <span id="statusCheckpoint"></span>
    </form>
    <h4>Checkpoints:</h4>
    <% for (const checkpoint of checkpoints[modelIndex]) { %>
        <a href="/api/actions/projects/<%= project.id %>/model/<%= models[modelIndex].id %>/checkpoint/<%= checkpoint.id %>/download"><%= checkpoint.fileName %></a> ...
        <a href="/api/actions/projects/<%= project.id %>/model/<%= models[modelIndex].id %>/checkpoint/<%= checkpoint.id %>/delete">[X]</a>
        <br />
    <% } %>
<% } %>
<hr />
<%- include('foot') -%>