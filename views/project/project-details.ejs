<%- include('head', { title: 'VolWeb' }) -%>
<script>
    function _(el) {
        return document.getElementById(el);
    }

    function progressHandler(event, progressBarId, statusId) {
        const percent = (event.loaded / event.total) * 100;
        _(progressBarId).value = Math.round(percent);
        _(statusId).innerHTML = Math.round(percent) + "% uploaded... please wait";
    }

    function completeHandler(event, progressBarId, statusId) {
        _(statusId).innerHTML = event.target.responseText;
        const progressBar = _(progressBarId);
        progressBar.value = 0;
        _(progressBarId).style.display = 'none';
    }

    function uploadFile(apiURL, filesField, progressBarId, statusId) {
        const files = _(filesField).files;

        const formdata = new FormData();
        for ( let i = 0; i < files.length; i++ ) {
            console.log(files[i]);
            formdata.append('files', files[i]);
        }
        const ajax = new XMLHttpRequest();
        _(progressBarId).style.display = 'block';
        ajax.upload.addEventListener("progress", (e) => progressHandler(e, progressBarId, statusId), false);
        ajax.addEventListener("load", (e) => completeHandler(e, progressBarId, statusId), false);
        ajax.addEventListener("error", (e) => errorHandler(e, statusId), false);
        ajax.addEventListener("abort", (e) => abortHandler(e, statusId), false);
        // Handle potential redirects
        ajax.onload = function() {
            if (ajax.responseURL) {
                window.location.href = ajax.responseURL;
            }
        };

        ajax.open("POST", apiURL);
        ajax.send(formdata);
    }
</script>
<a href="/api/actions/projects">Back to projects list.</a>
<br />
<h1>Vol Web</h1>
<h2>Project <%= project.details.name %>:</h2>
<p><b>Owner ID:</b> <%= project.details.userId %></p>
<p><b>Description:</b> <%= project.details.description %></p>

<br />
<h3 style="text-align: left">Volumes:</h3>
<button id="createVolumeToggle" onClick="(() => {
    const disp = document.getElementById('createVolume').style.display;
    document.getElementById('createVolume').style.display = disp === 'block' ? 'none' : 'block';
    document.getElementById('createVolumeToggle').textContent = disp === 'block' ? 'Add New Volume &darr;' : 'Add New Volume &uarr;';
    })()">Add New Volume &darr;</button>
<form id="createVolume" style="display: none" action="/api/actions/projects/<%= project.details.id %>/create-volume" method="post" enctype="multipart/form-data">
    <label for="name">Volume name:</label>
    <input type="text" name="name" /> <br />
    <br />
    <label for="description">Volume description:</label>
    <textarea name="description" rows="4" cols="25"></textarea>
    <input type="submit" value="Add" />
</form>
<hr />
<% for (const volume of project.volumes) { %>
    <p>
        <b>Volume:</b> <%= volume.details.name %> (<%= volume.details.id %>)
        <a href="/api/actions/projects/<%= project.details.id %>/volume/<%= volume.details.id %>/delete">[X]</a>
    </p>
    <p>
        <a href="/api/actions/projects/<%= project.details.id %>/volume/<%= volume.details.id %>/test-tiff">Tiff Test</a>
    </p>
    <h4>Raw Data:</h4>
    <% if (volume.rawData != null) { %>
        <% if (volume.rawData.mrcFile != null) { %>
            <a href="/api/actions/projects/<%= project.details.id %>/volumeData/<%= volume.rawData.id %>/download-mrc-file"><%= volume.rawData.mrcFile.fileName %></a> ...
            <a href="/api/actions/projects/<%= project.details.id %>/volumeData/<%= volume.rawData.id %>/delete-mrc-file">[X]</a>
            <br />
        <% } %>
        <% if (volume.rawData.rawFile != null) { %>
            <a href="/api/actions/projects/<%= project.details.id %>/volumeData/<%= volume.rawData.id %>/download-raw-file"><%= volume.rawData.rawFile.fileName %></a> ...
            <a href="/api/actions/projects/<%= project.details.id %>/volumeData/<%= volume.rawData.id %>/delete-raw-file">[X]</a>
            <br />
        <% } %>
        <% if (volume.rawData.settingsFile != null) { %>
            <a href="/api/actions/projects/<%= project.details.id %>/volumeData/<%= volume.rawData.id %>/download-settings-file"><%= volume.rawData.settingsFile.fileName %></a> ...
            <a href="/api/actions/projects/<%= project.details.id %>/volumeData/<%= volume.rawData.id %>/delete-settings-file">[X]</a><br />
        <% } %>
        <% if (volume.rawData.rawFile != null && volume.rawData.settingsFile != null) { %>
            <a target="_blank" href="/api/actions/projects/<%= project.details.id %>/volumeData/<%= volume.rawData.id %>/visualize">Visualize Raw Volume</a><br />
        <% } %>
    <% } %>
    <form method="POST" enctype="multipart/form-data" id="rawDataUpload">
        <label for="file">Select Raw Data Volume files:</label>
        <input type="file" id="rawDataFiles_<%= volume.details.id %>" name="files" accept="image/tif,image/tiff,application/zip,.raw,.json" multiple>
        <input
                type="button"
                onclick="uploadFile('/api/actions/projects/<%= project.details.id %>/volume/<%= volume.details.id %>/raw-data/upload', 'rawDataFiles_<%= volume.details.id %>', 'progressBarRawData_<%= volume.details.id %>', 'statusRawData_<%= volume.details.id %>')"
                value = "Upload">
        <progress id="progressBarRawData_<%= volume.details.id %>" value="0" max="100" style="width:300px; display: none"></progress>
        <span id="statusRawData_<%= volume.details.id %>"></span>
    </form>
    <form method="POST" enctype="multipart/form-data" id="rawDataUpload">
        <label for="file">Select MRC file:</label>
        <input type="file" id="mrcFile_<%= volume.details.id %>" name="files" accept=".mrc">
        <input
            type="button"
            onclick="uploadFile('/api/actions/projects/<%= project.details.id %>/volume/<%= volume.details.id %>/raw-data/upload-mrc-file', 'mrcFile_<%= volume.details.id %>', 'progressBarMrcFile_<%= volume.details.id %>', 'statusMrcFile_<%= volume.details.id %>')"
            value = "Upload">
        <progress id="progressBarMrcFile_<%= volume.details.id %>" value="0" max="100" style="width:300px; display: none"></progress>
        <span id="statusMrcFile_<%= volume.details.id %>"></span>
    </form>
    <h4>Sparse Labels:</h4>
    <a href="/api/actions/projects/<%= project.details.id %>/volume/<%= volume.details.id %>/add-sparse-labeled-volume"><button>Add Sparse Labeled Volume</button></a>
    <br />
    <% for (const sparseLabeledVolume of volume.sparseLabeledVolumes) { %>
        <b>Sparse volume <%= sparseLabeledVolume.id %>:</b>
        <form method="POST" enctype="multipart/form-data">
            <label for="file">Select Sparse Labeled Volume files:</label>
            <input type="file" id="sparseLabeledVolumeFiles" name="files" accept="image/tif,image/tiff,application/zip,.raw,.json" multiple>
            <input
                    type="button"
                    onclick="uploadFile('/api/actions/projects/<%= project.id %>/volumeData/<%= sparseLabeledVolume.id %>/upload-files', 'sparseLabeledVolumeFiles', 'progressBarSparseLabeledVolume', 'statusSparseLabeledVolume')"
                    value = "Upload">
            <progress id="progressBarSparseLabeledVolume" value="0" max="100" style="width:300px; display: none"></progress>
            <span id="statusSparseLabeledVolume"></span>
        </form>
        <% if (sparseLabeledVolume.rawFile != null) { %>
            <a href="/api/actions/projects/<%= project.details.id %>/volumeData/<%= sparseLabeledVolume.id %>/download-raw-file"><%= sparseLabeledVolume.rawFile.fileName %></a> ...
            <a href="/api/actions/projects/<%= project.details.id %>/volumeData/<%= sparseLabeledVolume.id %>/delete-raw-file">[X]</a>
            <br />
        <% } %>
        <% if (sparseLabeledVolume.settingsFile != null) { %>
            <a href="/api/actions/projects/<%= project.details.id %>/volumeData/<%= sparseLabeledVolume.id %>/download-settings-file"><%= sparseLabeledVolume.settingsFile.fileName %></a> ...
            <a href="/api/actions/projects/<%= project.details.id %>/volumeData/<%= sparseLabeledVolume.id %>/delete-settings-file">[X]</a><br />
        <% } %>
        <% if (sparseLabeledVolume.rawFile != null && sparseLabeledVolume.settingsFile != null) { %>
            <a target="_blank" href="/api/actions/projects/<%= project.details.id %>/volumeData/<%= sparseLabeledVolume.id %>/visualize">Visualize Raw Volume</a><br />
        <% } %>
    <% } %>
    <h4>Pseudo Labels:</h4>
    <a href="/api/actions/projects/<%= project.details.id %>/volume/<%= volume.details.id %>/add-pseudo-labeled-volume"><button>Add Pseudo Labeled Volume</button></a>
    <% for (const pseudoLabeledVolume of volume.pseudoLabeledVolumes) { %>
        <form method="POST" enctype="multipart/form-data">
            <label for="file">Select Pseudo Labeled Volume files:</label>
            <input type="file" id="pseudoLabeledVolumeFiles" name="files" accept="image/tif,image/tiff,application/zip,.raw,.json" multiple>
            <input
                    type="button"
                    onclick="uploadFile('/api/actions/projects/<%= project.id %>/volumeData/<%= pseudoLabeledVolume.id %>/upload-files', 'pseudoLabeledVolumeFiles', 'progressBarPseudoLabeledVolume', 'pseudoSparseLabeledVolume')"
                    value = "Upload">
            <progress id="progressBarPseudoLabeledVolume" value="0" max="100" style="width:300px; display: none"></progress>
            <span id="pseudoSparseLabeledVolume"></span>
        </form>
        <% if (pseudoLabeledVolume.rawFile != null) { %>
            <a href="/api/actions/projects/<%= project.details.id %>/volumeData/<%= pseudoLabeledVolume.id %>/download-raw-file"><%= pseudoLabeledVolume.rawFile.fileName %></a> ...
            <a href="/api/actions/projects/<%= project.details.id %>/volumeData/<%= pseudoLabeledVolume.id %>/delete-raw-file">[X]</a>
            <br />
        <% } %>
        <% if (pseudoLabeledVolume.settingsFile != null) { %>
            <a href="/api/actions/projects/<%= project.details.id %>/volumeData/<%= pseudoLabeledVolume.id %>/download-settings-file"><%= pseudoLabeledVolume.settingsFile.fileName %></a> ...
            <a href="/api/actions/projects/<%= project.details.id %>/volumeData/<%= pseudoLabeledVolume.id %>/delete-settings-file">[X]</a><br />
        <% } %>
        <% if (pseudoLabeledVolume.rawFile != null && pseudoLabeledVolume.settingsFile != null) { %>
            <a target="_blank" href="/api/actions/projects/<%= project.details.id %>/volumeData/<%= pseudoLabeledVolume.id %>/visualize">Visualize Raw Volume</a><br />
        <% } %>
    <% } %>
    <hr />
<% } %>
<br />
<hr />
<h3 style="text-align: left">Models:</h3>
<button id="createModelToggle" onClick="(() => {
    const disp = document.getElementById('createModel').style.display;
    document.getElementById('createModel').style.display = disp === 'block' ? 'none' : 'block';
    document.getElementById('createModelToggle').textContent = disp === 'block' ? 'Add New Model &darr;' : 'Add New Model &uarr;';
    })()">Add New Model &darr;</button>
<form id="createModel" style="display: none" action="/api/actions/projects/<%= project.details.id %>/create-model" method="post" enctype="multipart/form-data">
    <label for="name">Volume name:</label>
    <input type="text" name="name" /> <br />
    <br />
    <label for="description">Volume description:</label>
    <textarea name="description" rows="4" cols="25"></textarea>
    <input type="submit" value="Add" />
</form>
<% for (const model of project.models) { %>
    <p>
        <b>Model:</b> <%= model.details.name %> (<%= model.details.id %>)
        <a href="/api/actions/projects/<%= project.details.id %>/model/<%= model.details.id %>/delete">[X]</a>
    </p>
    <form method="POST" enctype="multipart/form-data">
        <label for="file">Select Checkpoint files:</label>
        <input type="file" id="checkpointFiles" name="files" accept=".ckpt" multiple>
        <input
                type="button"
                onclick="uploadFile('/api/actions/projects/<%= project.details.id %>/model/<%= model.details.id %>/add-checkpoint', 'checkpointFiles', 'progressBarCheckpoint', 'statusCheckpoint')"
                value = "Upload">
        <progress id="progressBarCheckpoint" value="0" max="100" style="width:300px; display: none"></progress>
        <span id="statusCheckpoint"></span>
    </form>
    <h4>Checkpoints:</h4>
    <% for (const checkpoint of model.checkpoints) { %>
        <a href="/api/actions/projects/<%= project.details.id %>/model/<%= model.details.id %>/checkpoint/<%= checkpoint.id %>/download"><%= checkpoint.fileName %></a> ...
        <a href="/api/actions/projects/<%= project.details.id %>/model/<%= model.details.id %>/checkpoint/<%= checkpoint.id %>/delete">[X]</a>
        <br />
    <% } %>
<% } %>
<hr />
<%- include('foot') -%>