// Prisma schema docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int                     @id @default(autoincrement())
  username              String                  @unique
  name                  String
  email                 String
  passwordSalt          String
  passwordHash          String
  admin                 Boolean                 @default(false)
  projects              Project[]
  volumes               Volume[]
  rawVolumeData         RawVolumeData[]
  sparseLabelVolumeData SparseLabelVolumeData[]
  pseudoLabelVolumeData PseudoLabelVolumeData[]
  models                Model[]
  checkpoints           Checkpoint[]
  results               Result[]
  projectAccess         ProjectAccess[]
  TaskHistory           TaskHistory[]

  @@index(fields: [username])
}

model Project {
  id           Int      @id @default(autoincrement())
  name         String
  description  String
  owner        User     @relation(fields: [ownerId], references: [id])
  ownerId      Int
  publicAccess Int      @default(0) // 0 - private, 1 - public
  volumes      Volume[]
  models       Model[]

  projectAccess ProjectAccess[]

  @@index(fields: [ownerId])
}

model ProjectAccess {
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   Int
  accessLevel Int // 0 - read, 1 - write

  @@id([userId, projectId])
}

model Volume {
  id            Int                     @id @default(autoincrement())
  name          String
  description   String
  creator       User?                   @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  creatorId     Int?
  projects      Project[]
  rawData       RawVolumeData?          @relation(fields: [rawDataId], references: [id])
  rawDataId     Int?
  sparseVolumes SparseLabelVolumeData[]
  pseudoVolumes PseudoLabelVolumeData[]
  results       Result[]
  TaskHistory   TaskHistory[]
}

model RawVolumeData {
  id             Int      @id @default(autoincrement())
  path           String?
  creator        User?    @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  creatorId      Int?
  rawFilePath    String?
  sizeX          Int
  sizeY          Int
  sizeZ          Int
  ratioX         Float
  ratioY         Float
  ratioZ         Float
  skipBytes      Int
  isLittleEndian Boolean
  isSigned       Boolean
  addValue       Int
  bytesPerVoxel  Int
  usedBits       Int
  mrcFilePath    String?
  volumes        Volume[]
  results        Result[]
  // BytesPerVoxel   BytesPerVoxel? @relation(fields: [bytesPerVoxelId], references: [id])
  // bytesPerVoxelId Int?
  // UsedBits        UsedBits?      @relation(fields: [usedBitsId], references: [id])
  // usedBitsId      Int?
}

// model BytesPerVoxel {
//   id   Int             @id
//   name String
//   data RawVolumeData[]
// }

// model UsedBits {
//   id   Int             @id
//   name String
//   data RawVolumeData[]
// }

model SparseLabelVolumeData {
  id             Int                     @id @default(autoincrement())
  path           String?
  creator        User?                   @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  creatorId      Int?
  rawFilePath    String?
  sizeX          Int
  sizeY          Int
  sizeZ          Int
  ratioX         Float
  ratioY         Float
  ratioZ         Float
  skipBytes      Int
  isLittleEndian Boolean
  isSigned       Boolean
  addValue       Int
  bytesPerVoxel  Int
  usedBits       Int
  volumes        Volume[]
  derivedLabels  PseudoLabelVolumeData[]
  color          String?
}

model PseudoLabelVolumeData {
  id              Int                    @id @default(autoincrement())
  path            String?
  creator         User?                  @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  creatorId       Int?
  rawFilePath     String?
  sizeX           Int
  sizeY           Int
  sizeZ           Int
  ratioX          Float
  ratioY          Float
  ratioZ          Float
  skipBytes       Int
  isLittleEndian  Boolean
  isSigned        Boolean
  addValue        Int
  bytesPerVoxel   Int
  usedBits        Int
  volumes         Volume[]
  checkpoints     Checkpoint[]
  originalLabel   SparseLabelVolumeData? @relation(fields: [originalLabelId], references: [id], onDelete: SetNull)
  originalLabelId Int?
}

model Model {
  id          Int           @id @default(autoincrement())
  name        String
  description String
  creator     User?         @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  creatorId   Int?
  projects    Project[]
  checkpoints Checkpoint[]
  TaskHistory TaskHistory[]
}

model Checkpoint {
  id          Int                     @id @default(autoincrement())
  filePath    String?
  folderPath  String?
  creator     User?                   @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  creatorId   Int?
  models      Model[]
  results     Result[]
  labels      PseudoLabelVolumeData[]
  TaskHistory TaskHistory[]
}

model Result {
  id               Int           @id @default(autoincrement())
  folderPath       String?
  files            ResultFile[]
  rawVolumeChannel Int?
  logFile          String?
  creator          User?         @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  creatorId        Int?
  checkpoint       Checkpoint    @relation(fields: [checkpointId], references: [id])
  checkpointId     Int
  volumeData       RawVolumeData @relation(fields: [volumeDataId], references: [id])
  volumeDataId     Int
  volumes          Volume[]
}

model ResultFile {
  id               Int    @id @default(autoincrement())
  name             String
  rawFileName      String
  settingsFileName String
  index            Int
  result           Result @relation(fields: [resultId], references: [id], onDelete: Cascade)
  resultId         Int
}

model TaskHistory {
  id           Int         @id @default(autoincrement())
  taskType     Int // Types: 0 - LabelInference, 1 - Training, 2 - Inference, 3 - Reconstruction
  taskStatus   Int // Status: 0 - Enqueued, 1 - Running, 2 - Finished, 3 - Failed
  user         User        @relation(fields: [userId], references: [id])
  userId       Int
  logFile      String?
  enqueuedTime DateTime
  startTime    DateTime?
  endTime      DateTime?
  volume       Volume?     @relation(fields: [volumeId], references: [id], onDelete: SetNull)
  volumeId     Int?
  model        Model?      @relation(fields: [modelId], references: [id], onDelete: SetNull)
  modelId      Int?
  checkpoint   Checkpoint? @relation(fields: [checkpointId], references: [id], onDelete: SetNull)
  checkpointId Int?
}
