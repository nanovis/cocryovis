{
  "name": "@cocryovis/server",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "prisma:init": "prisma migrate dev --name init",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:db": "npx prisma studio",
    "prisma:seed": "npx prisma db seed",
    "db:setup": "npm run prisma:deploy && npm run prisma:seed",
    "prisma:seed:users": "tsx prisma/seeds/test-users.ts",
    "start": "node dist/index.js",
    "start:prod": "npm run db:setup && npm run start",
    "dev": "tsx src/index.ts",
    "dev:env": "conda run --no-capture-output -p ./.venv tsx src/index.ts",
    "build": "tsup",
    "modules:install": "tsx src/tools/install-submodules.ts",
    "modules:create": "tsx src/tools/create-module-template.ts",
    "tscheck": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "npx eslint .",
    "upgrade:check": "npx npm-check-updates --format group",
    "upgrade:interactive": "npx npm-check-updates -i",
    "upgrade": "npx npm-check-updates -u"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CirilBohak/vol-web-server.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/CirilBohak/vol-web-server/issues"
  },
  "homepage": "https://github.com/CirilBohak/vol-web-server#readme",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@cocryovis/schemas": "1.0.0",
    "@prisma/client": "^6.19.2",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "async-express-decorator": "^1.1.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "better-sqlite3-session-store": "^0.1.0",
    "body-parser": "^2.2.2",
    "child-process": "^1.0.2",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-fileupload": "^1.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "npm-check-updates": "^21.0.0",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.20.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-fileupload": "^1.5.1",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.6.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "eslint": "^10.2.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "globals": "^17.5.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "prisma": "^6.19.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  }
}
