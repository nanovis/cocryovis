{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "./dist",

    "target": "ES2024",
    "module": "es2022",
    "moduleResolution": "bundler",
    "strict": false,
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": false,
    "paths": {
      "@cocryovis/schemas": ["../schemas/src"],
      "@cocryovis/schemas/*": ["../schemas/src/*"]
    }
  },
  "include": ["src"]
}
