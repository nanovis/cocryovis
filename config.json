{
    "idleSessionExpirationMin": 30,
    "tempPath": "./temp",
    "annotationsCachePath": "./temp/annotations/",
    "mrcCachePath": "./temp/mrc/",
    "dataPath": "./data",
    "maxVolumeChannels": 4,
    "safeMode": false,
    "logPath": "./logs/",
    "ilastikQueueSize": 20,
    "gpuQueueSize": 20,
    "ilastik": {
        "path": "./modules/ilastik/ilastik",
        "scripts_path": "bin/",
        "python": "./modules/ilastik/ilastik/bin/python",
        "inference": "run_ilastik.sh",
        "create_project_command": "train_headless.py",
        "model_file_name": "model_project.ilp",
        "workCache": "temp/ilastik",
        "cleanTemporaryFiles": true
    },
    "nanoOetzi": {
        "path": "./modules/nano-oetzi/",
        "scripts": "segmentation/",
        "python": "python",
        "workCache": "temp/nano-oetzi",
        "meanFiltering": {
            "command": "mean_filtering.py"
        },
        "inference": {
            "command": "inference_script.py",
            "defaultModel": "four_classes_model.ckpt",
            "cleanTemporaryFiles": true
        },
        "training": {
            "command": "train.py",
            "min_epochs": 1,
            "max_epochs": 1
        }
    },
    "Proximal_CryoET": {
        "path": "./modules/Proximal_CryoET/",
        "executable": "CUDA_PROXIMAL_SART"
    }
}
