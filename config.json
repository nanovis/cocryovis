{
    "annotationsCachePath": "./cache/annotations/",
    "volumeDataPath": "./data/volume-data/",
    "checkpointsPath": "./data/checkpoints/",
    "resultsPath": "./data/results/",
    "maxVolumeChannels": 4,
    "safeMode": false,
    "logPath": "./logs/",
    "ilastik": {
        "path": "../ilastik/",
        "scripts_path": "../ilastik/bin/",
        "python": "../ilastik/bin/python",
        "inference": "run_ilastik.sh",
        "create_project_command": "train_headless.py",
        "model_file_name": "model_project.ilp",
        "workCache": "cache/ilastik"
    },
    "nanoOetzi": {
        "path": "../nano-oetzi/",
        "data": "../nano-oetzi/data/",
        "models": "../nano-oetzi/models/",
        "scripts": "../nano-oetzi/segmentation/",
        "python": "python",
        "workCache": "cache/nano-oetzi",
        "maxQueueSize": 20,
        "inference": {
            "command": "inference_script.py",
            "defaultModel": "four_classes_model.ckpt"
        },
        "training": {
            "command": "train.py",
            "min_epochs": 1,
            "max_epochs": 1
        }
    }
}
